{
	"info": {
		"_postman_id": "dc710d0d-d9db-48ba-b0bb-2b61bbb2d8b4",
		"name": "API Automation Learning Path",
		"description": "A hands-on collection for learning API automation with Postman. Built around DummyJSON (https://dummyjson.com), a free public mock API — no API key required.\n\nLearning path:\n1. Auth — login, refresh token, get current user (token chaining)\n2. Products — full CRUD + search\n3. Users — list + create\n4. Todos — list + create\n\nEach request has test scripts (pm.test) that check status codes, validate response shape, and save values into environment variables for the next request to use. Run the whole collection top to bottom with the Collection Runner to see automation in action.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "47506116",
		"_collection_link": "https://sumudu-rightmo-4006329.postman.co/workspace/Sumudu-Tharanga's-Workspace~fcceda1e-eced-4ac2-8663-9a66d07cb6a4/collection/47506116-dc710d0d-d9db-48ba-b0bb-2b61bbb2d8b4?action=share&source=collection_link&creator=47506116"
	},
	"item": [
		{
			"name": "1. Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response contains a token\", function () {",
									"    var jsonData = pm.response.json();",
									"    var token = jsonData.accessToken || jsonData.token;",
									"    pm.expect(token).to.be.a('string').and.not.empty;",
									"    pm.environment.set(\"access_token\", token);",
									"    if (jsonData.refreshToken) {",
									"        pm.environment.set(\"refresh_token\", jsonData.refreshToken);",
									"    }",
									"});",
									"",
									"pm.test(\"Response time is acceptable\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(5000);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"expiresInMins\": 30\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Logs in and captures the access token into the environment for use by every later request."
					},
					"response": []
				},
				{
					"name": "Get Current User (Me)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Returns the logged-in user\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('username');",
									"    pm.environment.set(\"user_id\", jsonData.id);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/auth/me",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"me"
							]
						},
						"description": "Uses the access_token saved from Login to fetch the authenticated user. Demonstrates variable chaining between requests."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"New token issued\", function () {",
									"    var jsonData = pm.response.json();",
									"    var token = jsonData.accessToken || jsonData.token;",
									"    pm.expect(token).to.be.a('string').and.not.empty;",
									"    pm.environment.set(\"access_token\", token);",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refresh_token}}\",\n  \"expiresInMins\": 30\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/refresh",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"refresh"
							]
						},
						"description": "Shows how to rotate an access token without logging in again."
					},
					"response": []
				}
			]
		},
